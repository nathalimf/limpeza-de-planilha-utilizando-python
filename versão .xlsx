import pandas as pd
import os

# --- PASSO 1: Identificar colunas para remover conforme o arquivo .txt ---
colunas_para_remover = []
try:
    with open('base de dados1.txt', 'r', encoding='utf-8') as file:
        for linha in file:
            if ':' in linha:
                partes = linha.split(':', 1)
                nome_coluna = partes[0].strip()
                if "source" in nome_coluna.lower():
                    continue
                status = partes[1].strip()
                if status == "Não":
                    colunas_para_remover.append(nome_coluna)
except FileNotFoundError:
    print("Aviso: Arquivo 'base de dados1.txt' não encontrado. Nenhuma coluna será removida por esse critério.")

# --- PASSO 2: Carregar a Planilha ---
# Nota: Se o seu arquivo for .csv, mude para pd.read_csv
nome_arquivo_excel = '2025 SINISTROS.xlsx' 

if os.path.exists(nome_arquivo_excel):
    # Se for CSV, use: df = pd.read_csv(nome_arquivo_excel, sep=',')
    df = pd.read_excel(nome_arquivo_excel)

    # --- PASSO 3: Remover Colunas Indesejadas ---
    df = df.drop(columns=colunas_para_remover, errors='ignore')

    # --- PASSO 4: Remover Duplicatas ---
    if 'id_sinistro' in df.columns:
        antes = len(df)
        df = df.drop_duplicates(subset=['id_sinistro'], keep='first')
        print(f"Duplicatas removidas: {antes - len(df)} linhas repetidas deletadas.")
    else:
        df = df.drop_duplicates()
        print("Aviso: 'id_sinistro' não encontrado. Removendo apenas linhas 100% idênticas.")

    # --- PASSO 5: Tratar Valores Vazios (O QUE VOCÊ PEDIU) ---
    # Preenche todos os valores nulos (NaN) com 0 antes de converter para string
    df = df.fillna(0)

    # --- PASSO 6: Padronizar para MAIÚSCULO ---
    # Aplicamos apenas em colunas de texto (object)
    colunas_texto = df.select_dtypes(include=['object']).columns
    for col in colunas_texto:
        # Apenas aplica upper/strip se o conteúdo for string (evita erro em zeros)
        df[col] = df[col].apply(lambda x: str(x).upper().strip() if not isinstance(x, (int, float)) else x)

    # --- PASSO 7: Exportar Resultado ---
    nome_saida = '2025 SINISTROS LIMPA.xlsx'
    df.to_excel(nome_saida, index=False)
    print(f"Sucesso! Arquivo '{nome_saida}' pronto.")
else:
    print(f"Erro: O arquivo {nome_arquivo_excel} não foi encontrado.")
